---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import { buttonVariants } from '@/components/ui/button'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { getRecentPosts } from '@/lib/data-utils'

// Latest blog post
const latestPost = (await getRecentPosts(1))[0] ?? null

// Featured project — live star count from GitHub API
interface FeaturedProject {
  name: string; description: string; stars: number; language: string; url: string; homepage: string
}
let featuredProject: FeaturedProject = {
  name: 'advanced-android-project-view',
  description: 'Enhances Android Studio project view with quick access to commonly used directories and files.',
  stars: 4,
  language: 'Kotlin',
  url: 'https://github.com/z8dn/advanced-android-project-view',
  homepage: 'https://plugins.jetbrains.com/plugin/26764',
}
try {
  const r = await fetch('https://api.github.com/repos/z8dn/advanced-android-project-view',
    { headers: { 'Accept': 'application/vnd.github+json' } })
  if (r.ok) {
    const d = await r.json()
    featuredProject = {
      name: d.name,
      description: d.description ?? featuredProject.description,
      stars: d.stargazers_count,
      language: d.language,
      url: d.html_url,
      homepage: d.homepage ?? featuredProject.homepage,
    }
  }
} catch { /* use fallback */ }

// Fetch GitHub contributions from both accounts at build time
interface GhContribution { date: string; count: number }

let ghContributions: GhContribution[] = [];
let ghTotal = 0;

try {
  const [r1, r2] = await Promise.all([
    fetch('https://github-contributions-api.jogruber.de/v4/z8dn?y=last'),
    fetch('https://github-contributions-api.jogruber.de/v4/z8dn-anz?y=last'),
  ]);
  const [d1, d2] = await Promise.all([r1.json(), r2.json()]);

  const merged = new Map<string, number>();
  const add = (list: { date: string; count: number }[]) =>
    list.forEach(c => merged.set(c.date, (merged.get(c.date) ?? 0) + c.count));
  add(d1.contributions ?? []);
  add(d2.contributions ?? []);

  ghContributions = [...merged.entries()]
    .map(([date, count]) => ({ date, count }))
    .sort((a, b) => a.date.localeCompare(b.date));
  ghTotal = ghContributions.reduce((s, c) => s + c.count, 0);
} catch (e) {
  console.warn('[index] GitHub contributions fetch failed:', e);
}

const ghData = JSON.stringify({ contributions: ghContributions, total: ghTotal });
---

<Layout class="max-w-6xl">
  <PageHead slot="head" title="Home" />
  <div class="bg-grid" aria-hidden="true"></div>

  <!--
    col:  1              2              3
    row1: [intro        ][placeholder  ][career     ]
    row2: [location     ][featured     ][career     ]
    row3: [activity     ][social       ][time-coding]
    row4: [latest-post  ][·············][time-coding]
  -->
  <section class="grid grid-cols-3 gap-1.5 lg:gap-2.5 max-sm:block max-sm:space-y-2">

    <!-- Intro — col1-2 row1 -->
    <div class="[grid-column:1/3] [grid-row:1] flex flex-col justify-center rounded-[0.625rem] border bg-background p-2.5 lg:p-5">
      <h1 class="text-[1.75rem] font-semibold tracking-[-0.04em] leading-tight">Hey, I'm Zayden 👋</h1>
      <p class="text-muted-foreground mt-0.5 text-[0.8125rem]">
        also known as <span class="text-foreground font-medium">z8dn</span>
      </p>
      <p class="text-muted-foreground text-[0.775rem] leading-[1.6] mt-2" style="text-wrap:pretty">
        I build mobile apps and developer tools that make people's lives a little better. Somewhere between shipping features and obsessing over build times, I started writing — not to teach, but to think out loud and share the journey with anyone who'll come along for the ride.
      </p>
    </div>

    <!-- Location / Now — col1 row2 -->
    <div class="[grid-column:1] [grid-row:2] flex flex-col gap-y-2 rounded-[0.625rem] border bg-background p-2.5 lg:p-5">
      <div>
        <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase mb-2">
          <Icon name="lucide:map-pin" class="size-[11px]" />
          Location
        </p>
        <div class="flex items-center gap-2">
          <p class="text-[0.875rem] font-medium">Ho Chi Minh City</p>
          <span id="online-dot" class="inline-flex items-center gap-1 rounded-full border px-1.5 py-0.5 text-[0.6rem] font-medium tracking-wide uppercase">
            <span class="size-1.5 rounded-full bg-muted-foreground/40" id="online-dot-circle"></span>
            <span id="online-dot-label" class="text-muted-foreground">Offline</span>
          </span>
        </div>
        <p class="text-muted-foreground text-[0.75rem]">Vietnam · UTC+7</p>
        <p id="hcm-clock" class="text-[1.6rem] font-semibold tracking-tight tabular-nums mt-2">--:-- --</p>
      </div>
    </div>

    <!-- Featured project — col2 row2 -->
    <a
      href={featuredProject.url}
      target="_blank"
      rel="noopener noreferrer"
      class="[grid-column:2] [grid-row:2] bento-link rounded-[0.625rem] border bg-background p-2.5 lg:p-5 flex flex-col gap-y-2 group "
    >
      <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase">
        <Icon name="lucide:box" class="size-[11px]" />
        Featured project
      </p>
      <div class="flex flex-col gap-1 grow">
        <p class="text-[0.85rem] font-semibold leading-snug tracking-[-0.02em] group-hover:text-foreground transition-colors">
          Advanced Android<br />Project View
        </p>
        <p class="text-muted-foreground text-[0.75rem] leading-[1.55]" style="text-wrap:pretty">
          {featuredProject.description}
        </p>
      </div>
      <div class="flex items-center gap-2 mt-auto">
        <span class="inline-flex items-center gap-1 text-muted-foreground text-[0.7rem]">
          <span class="size-2 rounded-full bg-[#7F52FF] inline-block"></span>
          {featuredProject.language}
        </span>
        <span class="inline-flex items-center gap-0.5 text-muted-foreground text-[0.7rem]">
          <Icon name="lucide:star" class="size-[10px]" />
          {featuredProject.stars}
        </span>
        <span class="ml-auto inline-flex items-center gap-0.5 text-muted-foreground/50 text-[0.7rem] group-hover:text-muted-foreground transition-colors">
          <Icon name="lucide:puzzle" class="size-[10px]" />
          JetBrains Plugin
        </span>
      </div>
    </a>

    <!-- Career timeline — col3 rows1-2 -->
    <div class="[grid-column:3] [grid-row:1/3] flex flex-col gap-y-2 rounded-[0.625rem] border bg-background p-2.5 lg:p-5">
      <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase">
        <Icon name="lucide:briefcase" class="size-[11px]" />
        Career
      </p>
      <ol class="relative flex flex-col grow mx-1">
        <span class="absolute left-[5px] top-2 bottom-7 w-px bg-border/40 block"></span>
        {[
          { title: 'Technical Lead',   company: 'HCLTech · ANZ Plus', date: '2025 – now', active: true  },
          { title: 'Android Engineer', company: 'NAVER',               date: '2023 – 2025', active: false },
          { title: 'Role placeholder', company: 'Company',             date: '20xx – 20xx', active: false, dim: true },
          { title: 'Role placeholder', company: 'Company',             date: '20xx – 20xx', active: false, dim: true },
        ].map(item => (
          <li class="relative flex items-start gap-2.5 pb-3 last:pb-0">
            {item.active ? (
              <span class="relative z-10 mt-[3px] shrink-0 size-[11px] flex-none flex items-center justify-center">
                <span class="absolute inline-flex size-full rounded-full bg-emerald-500 opacity-60 animate-ping"></span>
                <span class="relative size-[7px] rounded-full bg-emerald-500 block"></span>
              </span>
            ) : (
              <span class="relative z-10 mt-[3px] shrink-0 size-[11px] flex-none flex items-center justify-center">
                <span class="size-[6px] rounded-full block" style="background:var(--muted-foreground);opacity:0.25"></span>
              </span>
            )}
            <div class="flex flex-col gap-0.5 min-w-0" style={item.active ? '' : 'opacity:0.35'}>
              <div class="flex items-baseline justify-between gap-1">
                <p class={`leading-snug truncate ${item.active ? 'text-[0.8rem] font-medium' : 'text-[0.78rem] font-normal text-muted-foreground'}`}>{item.title}</p>
                <p class="text-muted-foreground/60 text-[0.65rem] font-mono shrink-0">{item.date}</p>
              </div>
              <p class="text-muted-foreground text-[0.72rem]">{item.company}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>

    <!-- Skills / WakaTime — col3 rows3-4 -->
    <div class="[grid-column:3] [grid-row:3/5] rounded-[0.625rem] border bg-background p-2.5 lg:p-5">
      <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase mb-2">
        <Icon name="lucide:bar-chart-2" class="size-[11px]" />
        Time coding
      </p>
      <div class="flex flex-col gap-1.5">
        {[
          { name: 'Kotlin',     icon: 'simple-icons:kotlin',     hours: 842 },
          { name: 'TypeScript', icon: 'simple-icons:typescript', hours: 721 },
          { name: 'Gradle',     icon: 'simple-icons:gradle',     hours: 398 },
          { name: 'Android',    icon: 'simple-icons:android',    hours: 310 },
          { name: 'Astro',      icon: 'simple-icons:astro',      hours: 203 },
          { name: 'MDX',        icon: 'simple-icons:mdx',        hours: 167 },
          { name: 'Python',     icon: 'simple-icons:python',     hours: 134 },
        ].map((s, _, arr) => (
          <div class="skill-row">
            <div class="skill-icon" title={s.name}>
              <Icon name={s.icon} class="size-[13px] text-foreground/70" />
            </div>
            <div class="skill-bar-wrap">
              <div class="skill-bar-bg"></div>
              <div class="skill-bar-fill" style={`width:${(s.hours / arr[0].hours * 100).toFixed(1)}%`}></div>
            </div>
            <span class="skill-hours">{s.hours}h</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Activity heatmap — col1 row3 -->
    <div class="[grid-column:1] [grid-row:3] rounded-[0.625rem] border bg-background p-2.5 lg:p-5">
      <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase mb-2">
        <Icon name="lucide:activity" class="size-[11px]" />
        Activity
      </p>
      <div id="gh-graph-container"></div>
    </div>

    <!-- Latest post — col1-2 row4 -->
    {latestPost && (
      <a
        href={`/blog/${latestPost.id}`}
        class="[grid-column:1/3] [grid-row:4] bento-link rounded-[0.625rem] border bg-background p-2.5 lg:p-5 flex flex-col gap-1.5 group"
      >
        <p class="text-muted-foreground flex items-center gap-1.5 text-[0.6875rem] font-medium tracking-[0.08em] uppercase">
          <Icon name="lucide:file-text" class="size-[11px]" />
          Latest post
        </p>
        <p class="text-[0.8rem] font-medium leading-snug tracking-[-0.01em] grow group-hover:text-foreground transition-colors line-clamp-2" style="text-wrap:pretty">
          {latestPost.data.title}
        </p>
        <p class="text-muted-foreground/60 text-[0.7rem] font-mono">
          {latestPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </p>
      </a>
    )}

    <!-- Social chips — col2 row3 (last in DOM → bottom on mobile) -->
    <div class="[grid-column:2] [grid-row:3] flex items-center justify-center gap-2">
      {[
        { href: 'https://github.com/z8dn',               icon: 'simple-icons:github',   label: 'GitHub'   },
        { href: 'https://linkedin.com/in/z8dn',          icon: 'simple-icons:linkedin', label: 'LinkedIn' },
        { href: 'mailto:phunggiabuu30@gmail.com',         icon: 'lucide:mail',           label: 'Email'    },
        { href: 'https://medium.com/@z8dn',              icon: 'simple-icons:medium',   label: 'Medium'   },
      ].map(s => (
        <a
          href={s.href}
          target={s.href.startsWith('mailto') ? undefined : '_blank'}
          rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
          aria-label={s.label}
          class="size-7 rounded-[0.4rem] border bg-background flex items-center justify-center shrink-0 bento-link"
        >
          <Icon name={s.icon} class="size-[0.75rem] text-muted-foreground" />
        </a>
      ))}
    </div>

  </section>
</Layout>

<!-- GitHub contribution data (build-time fetched) -->
<script id="gh-data" type="application/json" set:html={ghData}></script>

<style is:global>
  /* Catppuccin Latte contribution colours */
  :root {
    --gh-0: #ccd0da;
    --gh-1: #b0d4a4;
    --gh-2: #82c37a;
    --gh-3: #5db054;
    --gh-4: #40a02b;
  }
  /* Catppuccin Mocha contribution colours */
  [data-theme='dark'] {
    --gh-0: #313244;
    --gh-1: #3b4f3b;
    --gh-2: #4e6a4c;
    --gh-3: #72a56e;
    --gh-4: #a6e3a1;
  }
  .gh-weeks { display: flex; gap: 3px; width: 100%; }
  .gh-week { flex: 1; display: flex; flex-direction: column; gap: 3px; }
  .gh-cell { border-radius: 2px; background: var(--gh-0); width: 100%; aspect-ratio: 1; }

  .gh-cell[data-level="1"] { background: var(--gh-1); }
  .gh-cell[data-level="2"] { background: var(--gh-2); }
  .gh-cell[data-level="3"] { background: var(--gh-3); }
  .gh-cell[data-level="4"] { background: var(--gh-4); }

  /* Background grid */
  .bg-grid {
    position: fixed;
    inset: 0;
    z-index: -1;
    background-image:
      linear-gradient(to right, var(--border) 1px, transparent 1px),
      linear-gradient(to bottom, var(--border) 1px, transparent 1px);
    background-size: 40px 40px;
    -webkit-mask-image: radial-gradient(ellipse 70% 65% at 50% 35%, black 0%, transparent 100%);
    mask-image: radial-gradient(ellipse 70% 65% at 50% 35%, black 0%, transparent 100%);
    pointer-events: none;
  }

  /* Skills bar chart */
  .skill-row { display: flex; align-items: center; gap: 8px; }
  .skill-icon {
    width: 22px; height: 22px; border-radius: 5px;
    background: var(--muted); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 9px; font-weight: 700;
    font-family: 'Geist Mono', ui-monospace, monospace;
    color: var(--muted-foreground);
    letter-spacing: -0.03em;
  }
  [data-theme='dark'] .skill-icon { background: oklch(0.22 0 0); }
  .skill-bar-wrap { flex: 1; position: relative; height: 10px; }
  .skill-bar-bg { position: absolute; inset: 0; background: var(--muted); border-radius: 3px; }
  [data-theme='dark'] .skill-bar-bg { background: oklch(0.2 0 0); }
  .skill-bar-fill {
    position: absolute; top: 0; left: 0; height: 100%; border-radius: 3px;
    background: var(--foreground); opacity: 0.15;
    transition: width 0.6s cubic-bezier(0.16,1,0.3,1);
  }
  [data-theme='dark'] .skill-bar-fill { opacity: 0.35; }
  .skill-hours {
    font-size: 11px; font-family: 'Geist Mono', ui-monospace, monospace;
    color: var(--muted-foreground); width: 36px; text-align: right; flex-shrink: 0;
  }

  /* Clickable bento glow */
  .bento-link {
    transition: box-shadow 0.2s ease;
  }
  .bento-link:hover {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--accent) 70%, transparent),
      0 0 14px 2px color-mix(in srgb, var(--accent) 20%, transparent);
  }
</style>

<script>
  // Module-level clock interval handle so we can clear it before each swap
  let _clockInterval: ReturnType<typeof setInterval> | null = null;

  function startClock() {
    const el = document.getElementById('hcm-clock');
    if (!el) return;
    const tick = () => {
      const now = new Date();
      const hcm = new Date(now.getTime() + (7 * 60 - now.getTimezoneOffset()) * 60000);
      const h = hcm.getUTCHours();
      const m = String(hcm.getUTCMinutes()).padStart(2, '0');
      const ampm = h >= 12 ? 'PM' : 'AM';
      el.textContent = `${h % 12 || 12}:${m} ${ampm}`;
    };
    tick();
    _clockInterval = setInterval(tick, 1000);
  }

  function checkOnline() {
    const dot = document.getElementById('online-dot');
    if (!dot) return;
    const utc7Hour = (new Date().getUTCHours() + 7) % 24;
    const circle = document.getElementById('online-dot-circle');
    const label = document.getElementById('online-dot-label');
    if (utc7Hour >= 9 && utc7Hour < 21) {
      circle?.classList.replace('bg-muted-foreground/40', 'bg-emerald-500');
      if (label) label.textContent = 'Online';
    }
  }

  function buildGhGraph() {
    const container = document.getElementById('gh-graph-container');
    if (!container) return;
    // Already rendered — skip (e.g. hot-reload without a full swap)
    if (container.hasChildNodes()) return;

    const raw = document.getElementById('gh-data');
    if (!raw) return;

    let contributions: { date: string; count: number }[] = [];
    try {
      const parsed = JSON.parse(raw.textContent ?? '{}');
      contributions = parsed.contributions ?? [];
    } catch { return; }

    const dateMap = new Map(contributions.map(c => [c.date, c.count]));

    // Level thresholds (quartiles of active days)
    const nonZero = contributions.map(c => c.count).filter(c => c > 0).sort((a, b) => a - b);
    const p = (pct: number) => nonZero[Math.floor(nonZero.length * pct)] ?? 1;
    const [t1, t2, t3] = [p(0.25), p(0.5), p(0.75)];
    const getLevel = (n: number) => !n ? 0 : n <= t1 ? 1 : n <= t2 ? 2 : n <= t3 ? 3 : 4;

    // Sunday-aligned weeks — ~11 weeks back
    const today = new Date(); today.setHours(0, 0, 0, 0);
    const cursor = new Date(today);
    cursor.setDate(cursor.getDate() - today.getDay());
    cursor.setDate(cursor.getDate() - 10 * 7);

    const weeks: ({ date: string; level: number } | null)[][] = [];

    while (cursor <= today) {
      const week: ({ date: string; level: number } | null)[] = [];
      for (let d = 0; d < 7; d++) {
        if (cursor > today) { week.push(null); }
        else {
          const key = cursor.toISOString().slice(0, 10);
          week.push({ date: key, level: getLevel(dateMap.get(key) ?? 0) });
        }
        cursor.setDate(cursor.getDate() + 1);
      }
      weeks.push(week);
    }

    // Drop trailing week if today is Sunday (only 1 visible square)
    if (weeks.length && weeks[weeks.length - 1].filter(d => d !== null).length <= 1) {
      weeks.pop();
    }

    const weeksRow = document.createElement('div'); weeksRow.className = 'gh-weeks';
    weeks.forEach(week => {
      const weekEl = document.createElement('div'); weekEl.className = 'gh-week';
      week.forEach(day => {
        const cell = document.createElement('div'); cell.className = 'gh-cell';
        if (day) {
          cell.setAttribute('data-level', String(day.level));
          cell.title = `${day.date} · ${dateMap.get(day.date) ?? 0}`;
        } else {
          cell.style.visibility = 'hidden';
        }
        weekEl.appendChild(cell);
      });
      weeksRow.appendChild(weekEl);
    });
    container.appendChild(weeksRow);
  }

  // Clear clock before Astro swaps the DOM (avoids stale element references)
  document.addEventListener('astro:before-swap', () => {
    if (_clockInterval !== null) {
      clearInterval(_clockInterval);
      _clockInterval = null;
    }
  });

  // Re-run on every navigation (initial load + client-side transitions)
  document.addEventListener('astro:page-load', () => {
    startClock();
    checkOnline();
    buildGhGraph();
  });
</script>
